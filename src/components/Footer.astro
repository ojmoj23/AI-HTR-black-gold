---
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = useTranslations(lang);
---

<footer class="border-t border-[#1a1a1a] py-10 px-6 lg:px-12">
  <div class="max-w-7xl mx-auto flex flex-col items-center gap-2 text-center sm:flex-row sm:justify-between sm:text-left">
    <div class="flex flex-col items-center gap-1 sm:flex-row sm:items-center sm:gap-3">
      <span class="font-display font-bold text-[#C9A84C] text-lg">AI HTR</span>
      <span class="hidden sm:block text-[#999] text-sm">·</span>
      <span class="text-[#999] text-sm">{tr.footer.tagline}</span>
    </div>
    <span class="text-[#999] text-sm">{tr.footer.copy}</span>
  </div>
</footer>
