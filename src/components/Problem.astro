---
import type { Lang } from '../i18n/translations';
import { useTranslations } from '../i18n/translations';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const tr = useTranslations(lang);
---

<section class="py-28 px-6 lg:px-12 bg-[#0D0D0D]">
  <div class="max-w-7xl mx-auto">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Left: text -->
      <div>
        <p class="text-[#C9A84C] text-xs font-semibold tracking-[0.22em] uppercase mb-6">{tr.problem.eyebrow}</p>
        <h2 class="font-display font-bold text-[clamp(28px,4vw,48px)] text-[#F0F0F0] leading-tight mb-6 max-w-lg">
          {tr.problem.heading}
        </h2>
        <div class="section-line mb-12"></div>

        <div class="flex flex-col gap-10">
          {[
            { num: '01', title: tr.problem.item1Title, text: tr.problem.item1Text },
            { num: '02', title: tr.problem.item2Title, text: tr.problem.item2Text },
            { num: '03', title: tr.problem.item3Title, text: tr.problem.item3Text },
          ].map(item => (
            <div class="flex gap-6">
              <span class="font-display text-[#2a2a2a] font-bold text-4xl leading-none flex-shrink-0 select-none">{item.num}</span>
              <div>
                <h3 class="text-[#E8E8E8] font-semibold text-base mb-2">{item.title}</h3>
                <p class="text-[#666] text-[15px] leading-relaxed">{item.text}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Right: OCR failure illustration -->
      <div class="flex flex-col gap-4 w-full">
        <div class="rounded-sm overflow-hidden border border-[#1a1a1a]">
          <img
            src={lang === 'ru' ? '/1.jpg' : '/2.jpg'}
            alt={lang === 'ru' ? 'Традиционный OCR не справляется' : 'Traditional OCR fails here'}
            class="w-full h-auto block scale-[1.08] origin-center"
          />
        </div>
        <!-- Label below image -->
        <div class="inline-flex items-center gap-3 px-4 py-2 bg-[#C9A84C11] border border-[#C9A84C22] self-start">
          <span class="w-1.5 h-1.5 rounded-full bg-[#C9A84C]"></span>
          <span class="text-[#C9A84C] text-xs font-medium tracking-wider uppercase">
            {lang === 'ru' ? 'Традиционный OCR не справляется' : 'Traditional OCR fails here'}
          </span>
        </div>
      </div>
    </div>
  </div>
</section>
